# Nomichi Trip Desk - Environment Variables Template
# Copy this file to .env.local and populate with your credentials.

# Supabase Configurations (Available in your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# AI Feature Endpoint Keys (Used server-side for WhatsApp message generation)
GROQ_API_KEY=gsk_your_groq_api_key_here
